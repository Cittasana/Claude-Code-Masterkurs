{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "dev",
            "path": "claude-code-masterkurs",
            "problemMatcher": {
                "owner": "vite",
                "pattern": { "regexp": "^$", "file": 1 },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Local:"
                }
            },
            "label": "npm: dev - claude-code-masterkurs",
            "isBackground": true,
            "runOptions": {
                "instanceLimit": 1
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
