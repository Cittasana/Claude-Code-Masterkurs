# ─────────────────────────────────────────────────────────────
# Frontend Environment Variables
# Copy to .env and fill in real values
# ─────────────────────────────────────────────────────────────

# Backend API URL
# Lokal:
VITE_API_URL=http://localhost:3000
# Produktion (Railway):
# VITE_API_URL=https://backend-production-9d7c.up.railway.app

# ─────────────────────────────────────────────────────────────
# Stripe (für Abo-Verwaltung)
# ─────────────────────────────────────────────────────────────
# Publishable Key von https://dashboard.stripe.com/apikeys
# WICHTIG: Für Test pk_test_... verwenden, für Live pk_live_...
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_xxx_oder_pk_live_xxx"

# Price IDs für die 3 Preismodelle von https://dashboard.stripe.com/products
# Erstelle 3 Produkte (Monatlich, Jährlich, Lifetime) und kopiere die Price-IDs hier rein:
VITE_STRIPE_PRICE_ID_MONTHLY="price_xxx"
VITE_STRIPE_PRICE_ID_YEARLY="price_xxx"
VITE_STRIPE_PRICE_ID_LIFETIME="price_xxx"

# ─────────────────────────────────────────────────────────────
# Discord (fuer Community-Widget auf dem Dashboard)
# ─────────────────────────────────────────────────────────────
# Server-ID fuer das Discord Widget (Rechtsklick auf Server → "Copy ID")
# VITE_DISCORD_SERVER_ID="your_discord_server_id"

# ─────────────────────────────────────────────────────────────
# Lokale Lehrvideos (lektion-XX.mp4)
# ─────────────────────────────────────────────────────────────
# Auf "true" setzen, sobald die Videos in /public/videos/
# verfuegbar bzw. an einen Host hochgeladen sind. Solange das
# Flag fehlt oder auf "false" steht, werden alle Video-Blocks
# mit provider: 'local' im Frontend ausgeblendet.
# VITE_VIDEOS_ENABLED=false

# ─────────────────────────────────────────────────────────────
# Optional: Analytics (Phase C)
# ─────────────────────────────────────────────────────────────
# VITE_PLAUSIBLE_DOMAIN=claude-code-masterkurs.de
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# ─────────────────────────────────────────────────────────────
# Hinweis: Für das Backend (server/) existiert eine eigene
# .env.example unter server/.env.example
# ─────────────────────────────────────────────────────────────
