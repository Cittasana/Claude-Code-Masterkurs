# ─────────────────────────────────────────────────────────────
# Frontend Environment Variables
# Copy to .env and fill in real values
# ─────────────────────────────────────────────────────────────

# Backend API URL
# Lokal:
VITE_API_URL=http://localhost:3000
# Produktion (Railway):
# VITE_API_URL=https://backend-production-9d7c.up.railway.app

# ─────────────────────────────────────────────────────────────
# Optional: Analytics (Phase C)
# ─────────────────────────────────────────────────────────────
# VITE_PLAUSIBLE_DOMAIN=claude-code-masterkurs.de
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# ─────────────────────────────────────────────────────────────
# Hinweis: Für das Backend (server/) existiert eine eigene
# .env.example unter server/.env.example
# ─────────────────────────────────────────────────────────────
