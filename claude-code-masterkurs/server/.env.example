# ─────────────────────────────────────────────────────────────
# Backend Environment Variables
# Copy to .env and fill in real values
# ─────────────────────────────────────────────────────────────

# Database (Railway setzt DATABASE_URL automatisch bei verknüpftem PostgreSQL Service)
DATABASE_URL="postgresql://user:password@localhost:5432/claude_code_masterkurs"

# JWT Secret (ÄNDERN! Mindestens 32 Zeichen, zufällig generiert)
# Generieren mit: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARS"

# CORS - Frontend URL(s), kommagetrennt
CORS_ORIGIN="http://localhost:5173"

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# E-Mail (optional, für Passwort-Reset)
# RESEND_API_KEY="re_xxx"

# Sentry Error Tracking (optional)
# DSN von https://sentry.io → Projekt erstellen → DSN kopieren
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

# Stripe (für Abo-Verwaltung)
# Von https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Stripe Price IDs (für Lifetime-Erkennung)
# Von https://dashboard.stripe.com/products
STRIPE_PRICE_ID_LIFETIME="price_xxx"

# Frontend URL (für Stripe Redirects)
FRONTEND_URL="http://localhost:5173"
