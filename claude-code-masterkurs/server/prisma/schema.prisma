// ─────────────────────────────────────────────────────────────
// Claude Code Masterkurs - Database Schema
// Mapped from the existing Frontend TypeScript types
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users & Auth ─────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  displayName   String   @default("Lernender")
  avatarEmoji   String   @default("🧑‍💻") @map("avatar_emoji")
  role          String   @default("user") // 'user' | 'admin'
  emailVerified    Boolean  @default(false) @map("email_verified")
  discordId        String?  @unique @map("discord_id")
  discordUsername   String?  @map("discord_username")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  progress           UserProgress?
  quizResults        QuizResult[]
  projectResults     ProjectResult[]
  challengeResults   ChallengeResult[]
  forumThreads       ForumThread[]
  forumReplies       ForumReply[]
  patterns           CommunityPattern[]
  srsItems           SRSItem[]
  analyticsEvents    AnalyticsEvent[]
  passwordResets     PasswordReset[]
  emailVerifications EmailVerification[]
  subscription       Subscription?
  showcaseEntries    ShowcaseEntry[]
  lektionen          Lektion[]          @relation("LektionAutor")
  researchHistory    ResearchHistory[]  @relation("ResearchHistoryUser")

  @@map("users")
}

// ── Password Reset Tokens ────────────────────────────────────────

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([userId])
  @@map("password_resets")
}

// ── Email Verification Tokens ────────────────────────────────────

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([userId])
  @@map("email_verifications")
}

// ── User Progress ────────────────────────────────────────────
// Maps to: UserProgress interface + SkillProgress

model UserProgress {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  lessonsCompleted  Int[]    @default([]) @map("lessons_completed")
  currentLesson     Int      @default(0) @map("current_lesson")
  totalPoints       Int      @default(0) @map("total_points")
  streak            Int      @default(0)
  lastSessionDate   DateTime @default(now()) @map("last_session_date")
  timeInvested      Int      @default(0) @map("time_invested") // minutes
  videosWatched     Json     @default("{}") @map("videos_watched") // Record<string, boolean>

  // Skill Progress (flattened from SkillProgress interface)
  skillInstallation    Int @default(0) @map("skill_installation")
  skillClaudeMd        Int @default(0) @map("skill_claude_md")
  skillMcpIntegration  Int @default(0) @map("skill_mcp_integration")
  skillCustomAgents    Int @default(0) @map("skill_custom_agents")
  skillProductionReady Int @default(0) @map("skill_production_ready")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_progress")
}

// ── Quiz Results ─────────────────────────────────────────────
// Maps to: QuizResult interface

model QuizResult {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  quizId    String   @map("quiz_id")
  lessonId  Int      @map("lesson_id")
  score     Int      @default(0)
  attempts  Int      @default(1)
  completed Boolean  @default(false)
  timestamp DateTime @default(now())

  @@unique([userId, quizId])
  @@map("quiz_results")
}

// ── Project Results ──────────────────────────────────────────
// Maps to: ProjectResult interface

model ProjectResult {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId         String   @map("project_id")
  completed         Boolean  @default(false)
  score             Int      @default(0)
  timestamp         DateTime @default(now())
  validationResults Json     @default("[]") @map("validation_results")
  // JSON: Array<{ testName: string; passed: boolean; points: number }>

  @@unique([userId, projectId])
  @@map("project_results")
}

// ── Challenge Results ────────────────────────────────────────
// Maps to: ChallengeResult interface

model ChallengeResult {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  challengeId String   @map("challenge_id")
  completed   Boolean  @default(false)
  score       Int      @default(0)
  maxScore    Int      @default(0) @map("max_score")
  timeUsed    Int      @default(0) @map("time_used") // seconds
  attempts    Int      @default(1)
  completedAt DateTime? @map("completed_at")

  @@unique([userId, challengeId])
  @@map("challenge_results")
}

// ── Forum ────────────────────────────────────────────────────
// Maps to: ForumThread + ForumReply interfaces

model ForumThread {
  id             String   @id @default(cuid())
  categoryId     String   @map("category_id") // 'allgemein' | 'lektionen' | 'projekte' | 'tipps' | 'feedback'
  title          String
  body           String
  authorId       String   @map("author_id")
  author         User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now()) @map("created_at")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  pinned         Boolean  @default(false)

  replies ForumReply[]

  @@index([categoryId])
  @@index([lastActivityAt])
  @@map("forum_threads")
}

model ForumReply {
  id        String   @id @default(cuid())
  threadId  String   @map("thread_id")
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  body      String
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([threadId])
  @@map("forum_replies")
}

// ── Community Patterns ───────────────────────────────────────
// Maps to: CommunityPattern interface

model CommunityPattern {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   // 'Prompts' | 'CLAUDE.md' | 'Workflows' | 'MCP' | 'Skills' | 'Sonstige'
  authorId    String   @map("author_id")
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  snippet     String
  language    String?
  tags        String[] @default([])
  useCase     String?  @map("use_case")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([category])
  @@map("community_patterns")
}

// ── Spaced Repetition (SRS) ──────────────────────────────────
// Maps to: SRSItem interface

model SRSItem {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  lessonId       Int      @map("lesson_id")
  nextReviewAt   DateTime @map("next_review_at")
  intervalIndex  Int      @default(0) @map("interval_index") // 0..3 → [1, 3, 7, 14] days
  lastReviewedAt DateTime? @map("last_reviewed_at")
  timesReviewed  Int      @default(0) @map("times_reviewed")

  @@unique([userId, lessonId])
  @@map("srs_items")
}

// ── Analytics Events ─────────────────────────────────────────
// Maps to: ActivityEvent interface from analyticsStore

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // 'lesson_complete' | 'quiz_complete' | 'project_complete' | 'session_start' | 'review_complete'
  timestamp DateTime @default(now())
  metadata  Json?    // { lessonId?, quizId?, projectId?, score?, duration? }

  @@index([userId, timestamp])
  @@index([type])
  @@map("analytics_events")
}

// ── Stripe Subscriptions ─────────────────────────────────────
// Manages user subscriptions with Stripe integration

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId     String    @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  
  status               String    @default("incomplete") // 'incomplete' | 'active' | 'canceled' | 'past_due' | 'trialing' | 'paused' | 'lifetime'
  isLifetime           Boolean   @default(false) @map("is_lifetime") // Lifetime Access gekauft?
  lifetimePurchasedAt  DateTime? @map("lifetime_purchased_at")
  
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  
  promoCodeId          String?   @map("promo_code_id")
  promoCode            PromoCode? @relation(fields: [promoCodeId], references: [id])
  promoAppliedAt       DateTime? @map("promo_applied_at")
  promoExpiresAt       DateTime? @map("promo_expires_at")
  
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([stripeCustomerId])
  @@index([isLifetime])
  @@map("subscriptions")
}

// ── Newsletter Subscribers ───────────────────────────────────
// Newsletter subscribers with double-opt-in

model NewsletterSubscriber {
  id              String    @id @default(cuid())
  email           String    @unique
  displayName     String?   @map("display_name")

  status          String    @default("pending") // 'pending' | 'active' | 'unsubscribed'
  source          String    @default("website") // 'website' | 'footer' | 'signup' | 'landing'

  confirmToken    String?   @unique @map("confirm_token")
  unsubscribeToken String   @unique @map("unsubscribe_token")

  subscribedAt    DateTime  @default(now()) @map("subscribed_at")
  confirmedAt     DateTime? @map("confirmed_at")
  unsubscribedAt  DateTime? @map("unsubscribed_at")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([status])
  @@index([confirmToken])
  @@index([unsubscribeToken])
  @@map("newsletter_subscribers")
}

// ── Promo Codes ──────────────────────────────────────────────
// Promo codes that can provide free subscription periods

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  
  durationMonths Int     @default(6) @map("duration_months") // How many months of free access
  maxUses       Int?    @map("max_uses") // null = unlimited
  timesUsed     Int     @default(0) @map("times_used")
  
  active        Boolean  @default(true)
  expiresAt     DateTime? @map("expires_at")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  subscriptions Subscription[]

  @@index([code])
  @@index([active])
  @@map("promo_codes")
}

// ── Showcase Entries ────────────────────────────────────────
// Student project showcase gallery (moderation required)

model ShowcaseEntry {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId   String?  @map("project_id")
  title       String
  description String
  githubUrl   String?  @map("github_url")
  liveUrl     String?  @map("live_url")
  imageUrl    String?  @map("image_url")
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([approved, createdAt])
  @@index([userId])
  @@map("showcase_entries")
}

// ── Admin CMS: Lektionen (Content Management) ─────────────────

model Lektion {
  id            String    @id @default(cuid())
  titel         String
  slug          String    @unique
  beschreibung  String?
  content       String    @db.Text
  kategorie     String    @default("basics") // 'basics' | 'fortgeschritten' | 'experten' | 'tools'
  reihenfolge   Int       @default(0)
  status        String    @default("draft") // 'draft' | 'published'
  publishedAt   DateTime? @map("published_at")

  autorId       String    @map("autor_id")
  autor         User      @relation("LektionAutor", fields: [autorId], references: [id])

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([kategorie])
  @@index([status])
  @@index([slug])
  @@map("lektionen")
}

// ── Admin CMS: Tools & Extensions ──────────────────────────────

model Tool {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  beschreibung  String?
  content       String?  @db.Text
  kategorie     String   @default("anfaenger") // 'anfaenger' | 'fortgeschritten' | 'experten' | 'mcp'
  icon          String   @default("Terminal")
  reihenfolge   Int      @default(0)
  status        String   @default("published") // 'draft' | 'published'

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([kategorie])
  @@index([slug])
  @@map("tools")
}

// ── Admin CMS: Agent Runs (Monitoring) ──────────────────────────

model AgentRun {
  id              String   @id @default(cuid())
  status          String   @default("running") // running | completed | failed
  trigger         String   @default("cron")    // cron | manual
  startedAt       DateTime @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  durationSeconds Int?     @map("duration_seconds")

  // Quality Metrics
  qualityScore    Float?   @map("quality_score")
  sourcesTotal    Int      @default(0) @map("sources_total")
  sourcesTier1    Int      @default(0) @map("sources_tier1")
  sourcesTier2    Int      @default(0) @map("sources_tier2")
  sourcesTier3    Int      @default(0) @map("sources_tier3")

  // Content Output
  lessonsCreated     Int      @default(0) @map("lessons_created")
  emailsCreated      Int      @default(0) @map("emails_created")
  socialPostsCreated Int      @default(0) @map("social_posts_created")
  researchTopics     String[] @default([]) @map("research_topics")

  // Raw Data
  summary         String?  @db.Text
  errorLog        String?  @db.Text @map("error_log")
  rawOutput       String?  @db.Text @map("raw_output")

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([status])
  @@index([startedAt])
  @@map("agent_runs")
}

// ── Admin CMS: Research History ────────────────────────────────

model ResearchHistory {
  id        String   @id @default(cuid())
  topic     String
  quelle    String   // 'web' | 'github' | 'stackoverflow' | 'docs'
  ergebnis  Json     @default("[]")

  userId    String   @map("user_id")
  user      User     @relation("ResearchHistoryUser", fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("research_history")
}

// ── Content Configs: Forum Categories ───────────────────────────

model ForumCategoryConfig {
  id          String   @id @default(cuid())
  categoryId  String   @unique @map("category_id")
  title       String
  description String
  icon        String   @default("")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("forum_category_configs")
}

// ── Content Configs: Official Docs ──────────────────────────────

model OfficialDoc {
  id          String   @id @default(cuid())
  title       String
  url         String
  category    String
  description String?
  lang        String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("official_docs")
}

// ── Content Configs: Feature Reference ──────────────────────────

model FeatureRef {
  id            String   @id @default(cuid())
  featureId     String   @unique @map("feature_id")
  name          String
  category      String
  description   String
  details       String?  @db.Text
  tips          Json     @default("[]")
  example       String
  documentation String
  tags          Json     @default("[]")
  lastUpdate    Boolean  @default(false) @map("last_update")
  bannerLabel   String?  @map("banner_label")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("feature_refs")
}

// ── Content Configs: Quizzes ────────────────────────────────────

model QuizConfig {
  id           String   @id @default(cuid())
  quizId       String   @unique @map("quiz_id")
  lessonId     Int      @map("lesson_id")
  title        String
  type         String
  points       Int      @default(5)
  passingScore Int      @default(80) @map("passing_score")
  maxAttempts  Int      @default(3) @map("max_attempts")
  questions    Json
  sortOrder    Int      @default(0) @map("sort_order")
  status       String   @default("published")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([lessonId])
  @@map("quiz_configs")
}

// ── Content Configs: Challenges ─────────────────────────────────

model ChallengeConfig {
  id            String   @id @default(cuid())
  challengeId   String   @unique @map("challenge_id")
  title         String
  description   String   @db.Text
  category      String
  source        String   @default("claude-code")
  difficulty    String
  timeLimit     Int      @default(0) @map("time_limit")
  points        Int      @default(100)
  instruction   String   @db.Text
  starterCode   String   @db.Text @map("starter_code")
  language      String   @default("typescript")
  hints         Json     @default("[]")
  validations   Json     @default("[]")
  solution      String   @db.Text
  relatedLessons Json    @default("[]") @map("related_lessons")
  sortOrder     Int      @default(0) @map("sort_order")
  status        String   @default("published")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([source])
  @@map("challenge_configs")
}

// ── Content Configs: Lesson Configs ─────────────────────────────

model LessonConfig {
  id          String   @id @default(cuid())
  lessonId    Int      @unique @map("lesson_id")
  level       Int      @default(1)
  title       String
  description String   @db.Text
  duration    String
  objectives  Json     @default("[]")
  content     Json
  track       String   @default("main")
  sortOrder   Int      @default(0) @map("sort_order")
  status      String   @default("published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([level])
  @@index([track])
  @@map("lesson_configs")
}

// ── Content Configs: Projects ───────────────────────────────────

model ProjectConfig {
  id            String   @id @default(cuid())
  projectId     String   @unique @map("project_id")
  level         Int      @default(1)
  title         String
  description   String   @db.Text
  difficulty    String
  duration      String
  requirements  Json     @default("[]")
  starterCode   String?  @db.Text @map("starter_code")
  hints         Json     @default("[]")
  solution      String?  @db.Text
  resources     Json     @default("[]")
  validationMeta Json    @default("{}") @map("validation_meta")
  sortOrder     Int      @default(0) @map("sort_order")
  status        String   @default("published")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([level])
  @@map("project_configs")
}

// ── Content Configs: Capstone Projects ──────────────────────────

model CapstoneConfig {
  id          String   @id @default(cuid())
  capstoneId  String   @unique @map("capstone_id")
  title       String
  description String   @db.Text
  difficulty  Int      @default(1)
  estimatedHours Int   @default(4) @map("estimated_hours")
  techStack   Json     @default("[]") @map("tech_stack")
  requirements Json    @default("[]")
  steps       Json     @default("[]")
  thumbnailEmoji String? @map("thumbnail_emoji")
  sortOrder   Int      @default(0) @map("sort_order")
  status      String   @default("published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("capstone_configs")
}

// ── Content Configs: Project Templates ──────────────────────────

model ProjectTemplateConfig {
  id              String   @id @default(cuid())
  templateId      String   @unique @map("template_id")
  title           String
  description     String   @db.Text
  difficulty      Int      @default(1)
  estimatedHours  Int      @default(4) @map("estimated_hours")
  techStack       Json     @default("[]") @map("tech_stack")
  features        Json     @default("[]")
  claudeMd        String   @db.Text @map("claude_md")
  fileStructure   String?  @db.Text @map("file_structure")
  steps           Json     @default("[]")
  githubUrl       String?  @map("github_url")
  sortOrder       Int      @default(0) @map("sort_order")
  status          String   @default("published")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("project_template_configs")
}

// ── Content Configs: Playground Tasks ───────────────────────────

model PlaygroundTaskConfig {
  id            String   @id @default(cuid())
  taskId        String   @unique @map("task_id")
  projectId     String   @map("project_id")
  title         String
  description   String   @db.Text
  instruction   String   @db.Text
  requirements  Json     @default("[]")
  mode          String   @default("editor")
  language      String   @default("typescript")
  starterCode   String   @db.Text @map("starter_code")
  hints         Json     @default("[]")
  validationMeta Json    @default("[]") @map("validation_meta")
  scenarioMeta   Json?   @map("scenario_meta")
  sortOrder      Int     @default(0) @map("sort_order")
  status         String  @default("published")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("playground_task_configs")
}
